#!/bin/bash
# Example launchd/cron wrapper for the omoikane detective librarian.
# Copy to your workspace, replace the placeholders, make executable.
#
# Placeholders:
#   <NODE_BIN_DIR>  dir holding the `pi` runtime (e.g. ~/.nvm/.../bin)
#   <WORKSPACE>     absolute path to this workspace dir
set -euo pipefail

# launchd/cron give a bare environment; set PATH so curl/jq/pi/python resolve.
export PATH="<NODE_BIN_DIR>:/opt/homebrew/bin:/usr/bin:/bin"

WORKDIR="<WORKSPACE>"
LOCK="$WORKDIR/.detective-session.lock"
cd "$WORKDIR"
ts() { date '+%Y-%m-%dT%H:%M:%S'; }

# Stale-aware single-flight lock: a killed session (no EXIT trap) must not
# block all future runs. Record pid; reclaim the lock if its holder is dead.
if ! mkdir "$LOCK" 2>/dev/null; then
    OLDPID=$(cat "$LOCK/pid" 2>/dev/null || echo "")
    if [[ -n "$OLDPID" ]] && kill -0 "$OLDPID" 2>/dev/null; then
    echo "$(ts) [skip] a detective session is already running"; exit 0
    fi
    echo "$(ts) [stale-lock] reclaiming lock from dead pid ${OLDPID:-unknown}"
    rm -rf "$LOCK"; mkdir "$LOCK" 2>/dev/null || { echo "$(ts) [skip] lost lock race"; exit 0; }
fi
echo $$ > "$LOCK/pid"
trap 'rm -rf "$LOCK" 2>/dev/null || true' EXIT

echo "=== $(ts) detective START ==="
# pi reads its model creds from ~/.pi/agent/auth.json (HOME-based);
# omoikane creds come from .agents/.local/kb-agent.json (NOT via env).
pi --print --skill .agents/skills/omoikane-detective --no-context-files \
   "Examine a batch from the detective backlog (up to 15): search incl. cross-language, judge, propose relations or no_action, then summary line."
rc=$?
echo "=== $(ts) detective END (rc=$rc) ==="
exit $rc
